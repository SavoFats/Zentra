{
  "version": 2,
  "builds": [
    { "src": "landing.html",       "use": "@vercel/static" },
    { "src": "index.html",         "use": "@vercel/static" },
    { "src": "index_staging.html", "use": "@vercel/static" },
    { "src": "privacy.html",       "use": "@vercel/static" },
    { "src": "terms.html",         "use": "@vercel/static" },
    { "src": "assets/**",          "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/",        "dest": "/landing.html" },
    { "src": "/app",     "dest": "/index.html" },
    { "src": "/staging", "dest": "/index_staging.html" },
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/terms",   "dest": "/terms.html" }
  ],
  "headers": [
    {
      "source": "/(app|staging|privacy|terms|)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
